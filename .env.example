# ============================================
# CommuteGo 2.0 Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=commutego

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600000

# ============================================
# TINYFISH API (Transportation Data)
# ============================================
# Get your API key from https://tinyfish.ai
# This is required for real transportation data
TINYFISH_API_KEY=your_tinyfish_api_key_here
TINYFISH_BASE_URL=https://agent.tinyfish.ai/v1
TINYFISH_RATE_PER_MINUTE=60
TINYFISH_RATE_PER_HOUR=1000
TINYFISH_CONCURRENT=5
TINYFISH_CACHE_TTL=300000
TINYFISH_TIMEOUT=30000

# ============================================
# GOOGLE MAPS API (Geocoding & Directions)
# ============================================
# Get your API key from Google Cloud Console
# Required for: Geocoding, Directions API, Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================
# RATE LIMITING (Optional - defaults provided)
# ============================================
AUTH_RATE_LIMIT_WINDOW=3600000
AUTH_RATE_LIMIT_MAX=10
GENERAL_RATE_LIMIT_WINDOW=900000
GENERAL_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW=60000
API_RATE_LIMIT_MAX=60

# ============================================
# ROUTE OPTIMIZATION WEIGHTS (Optional)
# ============================================
# Default balanced weights
WEIGHT_COST_DEFAULT=0.33
WEIGHT_TIME_DEFAULT=0.33
WEIGHT_CARBON_DEFAULT=0.34

# Cheapest preference weights
WEIGHT_COST_CHEAPEST=0.6
WEIGHT_TIME_CHEAPEST=0.2
WEIGHT_CARBON_CHEAPEST=0.2

# Fastest preference weights
WEIGHT_COST_FASTEST=0.2
WEIGHT_TIME_FASTEST=0.6
WEIGHT_CARBON_FASTEST=0.2

# Eco preference weights
WEIGHT_COST_ECO=0.2
WEIGHT_TIME_ECO=0.2
WEIGHT_CARBON_ECO=0.6

# ============================================
# CARBON EMISSION FACTORS (kg CO2 per km)
# ============================================
CARBON_WALK=0
CARBON_METRO=0.041
CARBON_TRAIN=0.041
CARBON_BUS=0.089
CARBON_CAB=0.192
CARBON_MIXED=0.107

# ============================================
# AVERAGE SPEEDS (km/h)
# ============================================
SPEED_WALK=5
SPEED_METRO=40
SPEED_TRAIN=60
SPEED_BUS=25
SPEED_CAB=30
SPEED_MIXED=35

# ============================================
# TRANSFER TIME (minutes)
# ============================================
TRANSFER_TIME=15